---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
---

<Base
  title="Pagina niet gevonden — Domeinscan | Packetflow"
  description="Deze pagina bestaat niet of is verplaatst."
>
  <section class="section notfound">
    <div class="container">
      <span class="kicker">404</span>
      <h1 class="notfound__title">Deze pagina bestaat niet (meer)</h1>
      <p class="lead notfound__lead">
        Misschien is de link verlopen of verkeerd getypt. Ga terug naar de
        domeinscan of naar de hoofdsite.
      </p>
      <div class="notfound__actions">
        <a class="nf-btn nf-btn--primary" href={base}>Naar de domeinscan</a>
        <a class="nf-btn nf-btn--secondary" href="https://www.packetflow.be"
          >Naar de hoofdsite</a
        >
      </div>
    </div>
  </section>
</Base>

<style>
  .notfound {
    text-align: center;
  }
  .notfound .kicker {
    justify-content: center;
  }
  .notfound__title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl, 2.25rem);
    margin: var(--space-3) 0 var(--space-4);
    color: var(--text-strong);
  }
  .notfound__lead {
    max-width: 46ch;
    margin: 0 auto;
  }
  .notfound__actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  /* Match the main site's Button (primary / secondary) — the shared Button
     component routes every href to the main site, so the "back to the tool"
     link uses these local styles instead. */
  .nf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 20px;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--fw-medium);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition:
      background var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .nf-btn--primary {
    background: var(--primary);
    color: var(--text-on-brand);
    border-color: var(--primary);
    box-shadow: var(--shadow-sm);
  }
  .nf-btn--primary:hover {
    background: var(--primary-hover);
    border-color: var(--primary-hover);
  }
  .nf-btn--secondary {
    background: transparent;
    color: var(--primary);
    border-color: var(--border-strong);
  }
  .nf-btn--secondary:hover {
    background: var(--orange-50);
  }
</style>
