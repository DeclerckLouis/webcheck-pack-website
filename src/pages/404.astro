---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
---

<Base title="Pagina niet gevonden — Domeinscan | PacketFlow">
  <section class="mx-auto max-w-xl px-5 py-24 text-center">
    <p class="text-6xl font-semibold text-[color:var(--color-brand)]">404</p>
    <h1 class="mt-4 text-2xl font-semibold">Deze pagina bestaat niet</h1>
    <p class="mt-3 text-[color:var(--color-muted)]">
      Misschien is de link verlopen of verkeerd getypt.
    </p>
    <a
      href={base}
      class="inline-block mt-6 px-6 py-3 rounded-xl bg-[color:var(--color-accent)] hover:bg-[color:var(--color-accent-deep)] text-white font-semibold transition-colors"
    >
      Terug naar de domeinscan
    </a>
  </section>
</Base>
