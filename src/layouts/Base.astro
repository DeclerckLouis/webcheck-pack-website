---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Domeinscan — controleer de gezondheid van uw domein | Packetflow",
  description =
    "Gratis check van uw domein: SPF, DMARC, DKIM, DNSSEC, mail, blacklists en meer. Krijg in enkele seconden een score van 0 tot 100.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(`${base}images/og-image.png`, Astro.site).toString();
const year = new Date().getFullYear();

// Structured data (comment: feeds the GEO/AI-visibility effort). Mirrors the
// main site's Packetflow business details; the tool itself is a WebApplication.
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "Domeinscan",
      url: canonical,
      applicationCategory: "SecurityApplication",
      operatingSystem: "Web",
      inLanguage: "nl-BE",
      description,
      offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
      provider: { "@id": "https://www.packetflow.be/#business" },
    },
    {
      "@type": "Organization",
      "@id": "https://www.packetflow.be/#business",
      name: "Packetflow",
      url: "https://www.packetflow.be",
      logo: "https://www.packetflow.be/images/og-image.png",
      email: "louis@packetflow.be",
      telephone: "+32 468 22 72 12",
      vatID: "BE 1024.713.047",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Hageweg 39",
        postalCode: "8490",
        addressLocality: "Jabbeke",
        addressRegion: "West-Vlaanderen",
        addressCountry: "BE",
      },
    },
  ],
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Packetflow" />
    <meta property="og:locale" content="nl_BE" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Lora:ital,wght@1,500;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-dvh flex flex-col" data-api-base={base}>
    <a href="#main" class="skip-link">Naar de inhoud</a>

    <header class="w-full">
      <div class="mx-auto max-w-5xl px-5 py-5 flex items-center gap-3">
        <svg viewBox="10 10 30 30" width="34" height="34" aria-hidden="true">
          <path
            d="M 10 10 L 10 40 L 25 40 L 25 25 C 25 16.7 31.7 10 40 10 L 10 10 Z"
            fill="var(--color-brand)"
          />
          <path
            d="M 40 40 L 25 40 L 25 25 C 25 33.3 31.7 40 40 40 Z"
            fill="var(--color-accent)"
          />
        </svg>
        <span class="font-semibold tracking-tight text-lg">Packetflow</span>
        <span class="text-[color:var(--color-muted)] text-sm hidden sm:inline"
          >· Domeinscan</span
        >
      </div>
    </header>

    <main id="main" class="flex-1 w-full">
      <slot />
    </main>

    <footer class="w-full border-t border-[color:var(--color-line)] mt-16">
      <div
        class="mx-auto max-w-5xl px-5 py-8 grid gap-6 sm:grid-cols-3 text-sm text-[color:var(--color-muted)]"
      >
        <div>
          <p class="font-semibold text-[color:var(--color-ink)]">Packetflow</p>
          <p class="mt-1">Uw lokale IT-partner in West-Vlaanderen.</p>
          <p class="mt-2">Hageweg 39, 8490 Jabbeke</p>
          <p>KBO BE 1024.713.047</p>
        </div>

        <div>
          <p class="font-semibold text-[color:var(--color-ink)]">Contact</p>
          <p class="mt-1">
            <a
              class="hover:text-[color:var(--color-brand)]"
              href="tel:+32468227212">+32 468 22 72 12</a
            >
          </p>
          <p>
            <a
              class="hover:text-[color:var(--color-brand)]"
              href="mailto:louis@packetflow.be">louis@packetflow.be</a
            >
          </p>
        </div>

        <nav class="flex flex-col gap-1 sm:items-end">
          <a class="hover:text-[color:var(--color-brand)]" href="https://www.packetflow.be"
            >Hoofdsite</a
          >
          <a
            class="hover:text-[color:var(--color-brand)]"
            href="https://www.packetflow.be/privacy">Privacybeleid</a
          >
          <a
            class="hover:text-[color:var(--color-brand)]"
            href="https://www.packetflow.be/contact">Contact</a
          >
        </nav>
      </div>

      <div
        class="mx-auto max-w-5xl px-5 pb-8 text-xs text-[color:var(--color-muted)]"
      >
        © {year} Packetflow — Lokaal · Persoonlijk · Scherp geprijsd.
      </div>
    </footer>
  </body>
</html>
