---
// "Wat klanten zeggen" — a static Google-reviews section. Renders nothing when
// there are no reviews yet (graceful, like the sector proof strip), so it's
// safe to drop on any page before reviews/GBP URL are filled in reviews.ts.
import Card from "@/components/Card.astro";
import Kicker from "@/components/Kicker.astro";
import Button from "@/components/Button.astro";
import Icon from "@/components/Icon.astro";
import { reviews, googleReviewsUrl } from "@/data/reviews";
import { site } from "@/data/site";

interface Props {
  title?: string;
}
const { title = "Wat klanten zeggen" } = Astro.props;
// Prefer the dedicated reviews URL; fall back to the GBP profile in site.ts so
// filling either source lights up the button.
const reviewsLink = googleReviewsUrl || site.profiles.googleBusiness;
---

{
  reviews.length > 0 && (
    <section class="section reviews">
      <div class="container">
        <div class="section-head">
          <Kicker>Geverifieerde Google-reviews</Kicker>
          <h2>{title}</h2>
        </div>
        <div class="reviews__grid">
          {reviews.map((r) => (
            <Card class="review">
              <div class="review__stars" aria-label={`${r.rating} van 5 sterren`}>
                {Array.from({ length: Math.round(r.rating) }).map(() => (
                  <Icon name="star" size={16} color="var(--orange-500, var(--orange-600))" />
                ))}
              </div>
              <p class="review__text">{r.text}</p>
              <div class="review__meta">
                <span class="review__author">{r.author}</span>
                {r.date && <span class="review__date">{r.date}</span>}
              </div>
            </Card>
          ))}
        </div>
        {reviewsLink && (
          <div class="reviews__cta">
            <Button
              href={reviewsLink}
              variant="secondary"
              iconRight="arrow-right"
            >
              Lees alle reviews op Google
            </Button>
          </div>
        )}
      </div>
    </section>
  )
}

<style>
  .reviews {
    background: var(--paper);
    border-block: 1px solid var(--border-soft);
  }
  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .review {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
  }
  .review__stars {
    display: inline-flex;
    gap: 2px;
    color: var(--orange-600);
  }
  .review__text {
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--text-body);
    /* Preserve the verbatim line breaks from the review text. */
    white-space: pre-line;
  }
  .review__meta {
    margin-top: auto;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .review__author {
    font-family: var(--font-sans);
    font-weight: var(--fw-semibold);
    font-size: var(--text-sm);
    color: var(--text-strong);
  }
  .review__date {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .reviews__cta {
    margin-top: var(--space-6);
  }
  /* keep in sync with --container-md in global.css */
  @media (max-width: 880px) {
    .reviews__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
